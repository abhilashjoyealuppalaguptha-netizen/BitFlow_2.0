# Verilog Sandbox API configuration
# Loaded by api/config.py via pydantic-settings.

DOCKER_IMAGE=verilog-sandbox:latest

# Simulation limits
TIMEOUT_SECONDS=30
MAX_TIMEOUT_SECONDS=120
MAX_SOURCE_BYTES=524288

# Docker container resource caps
MEM_LIMIT=128m
CPU_QUOTA=50000
CPU_PERIOD=100000
PIDS_LIMIT=64
NETWORK_DISABLED=true

# API behavior
CORS_ORIGINS=["*"]
LOG_LEVEL=INFO
INCLUDE_VCD_IN_RESPONSE=true

# Sandbox user inside the Docker image
SANDBOX_UID=10001
SANDBOX_GID=10001
