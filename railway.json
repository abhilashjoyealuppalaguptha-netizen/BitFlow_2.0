{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile.api"
    },
    "deploy": {
        "startCommand": "/bin/sh -c \"uvicorn api.main:app --host 0.0.0.0 --port $PORT\"",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 100
    }
}
