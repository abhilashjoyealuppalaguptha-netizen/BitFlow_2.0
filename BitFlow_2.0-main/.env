# .env — Local development overrides
# Created for Docker Compose integration and sibling container volume mapping.

# Host temporary directory (absolute path on the Windows host)
# This mapping allows sibling containers created by the API to access local workspace files.
HOST_TMP_DIR=C:/Users/User/OneDrive/Desktop/verilog_sandbox/tmp

# Standard defaults
DOCKER_IMAGE=verilog-sandbox:latest
TIMEOUT_SECONDS=30
MAX_TIMEOUT_SECONDS=120
MEM_LIMIT=128m
CPU_QUOTA=50000
CPU_PERIOD=100000
PIDS_LIMIT=64
NETWORK_DISABLED=true
MAX_SOURCE_BYTES=524288
LOG_LEVEL=INFO
INCLUDE_VCD_IN_RESPONSE=true
CORS_ORIGINS=["*"]
