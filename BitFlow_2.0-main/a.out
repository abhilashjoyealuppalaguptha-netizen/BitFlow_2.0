:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x644124657b60 .scope module, "tb_counter" "tb_counter" 2 15;
 .timescale -9 -12;
v0x644124649330_0 .var "clk", 0 0;
v0x64412464a910_0 .net "count", 3 0, v0x644124648280_0;  1 drivers
v0x64412464abe0_0 .var "en", 0 0;
v0x644124679ae0_0 .var/i "errors", 31 0;
v0x644124679b80_0 .var "rst", 0 0;
E_0x644124656eb0 .event negedge, v0x644124648080_0;
S_0x644124657cf0 .scope module, "dut" "counter" 2 27, 3 13 0, S_0x644124657b60;
 .timescale -9 -12;
    .port_info 0 /INPUT 1 "clk";
    .port_info 1 /INPUT 1 "rst";
    .port_info 2 /INPUT 1 "en";
    .port_info 3 /OUTPUT 4 "count";
P_0x644124657ed0 .param/l "WIDTH" 0 3 14, +C4<00000000000000000000000000000100>;
v0x644124648080_0 .net "clk", 0 0, v0x644124649330_0;  1 drivers
v0x644124648280_0 .var "count", 3 0;
v0x6441246489b0_0 .net "en", 0 0, v0x64412464abe0_0;  1 drivers
v0x644124649130_0 .net "rst", 0 0, v0x644124679b80_0;  1 drivers
E_0x64412461e880 .event posedge, v0x644124648080_0;
    .scope S_0x644124657cf0;
T_0 ;
    %wait E_0x64412461e880;
    %load/vec4 v0x644124649130_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.0, 8;
    %pushi/vec4 0, 0, 4;
    %assign/vec4 v0x644124648280_0, 0;
    %jmp T_0.1;
T_0.0 ;
    %load/vec4 v0x6441246489b0_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.2, 8;
    %load/vec4 v0x644124648280_0;
    %addi 1, 0, 4;
    %assign/vec4 v0x644124648280_0, 0;
T_0.2 ;
T_0.1 ;
    %jmp T_0;
    .thread T_0;
    .scope S_0x644124657b60;
T_1 ;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x644124679ae0_0, 0, 32;
    %end;
    .thread T_1;
    .scope S_0x644124657b60;
T_2 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x644124649330_0, 0, 1;
    %end;
    .thread T_2;
    .scope S_0x644124657b60;
T_3 ;
    %delay 5000, 0;
    %load/vec4 v0x644124649330_0;
    %inv;
    %store/vec4 v0x644124649330_0, 0, 1;
    %jmp T_3;
    .thread T_3;
    .scope S_0x644124657b60;
T_4 ;
    %vpi_call 2 42 "$dumpfile", "wave.vcd" {0 0 0};
    %vpi_call 2 43 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x644124657b60 {0 0 0};
    %end;
    .thread T_4;
    .scope S_0x644124657b60;
T_5 ;
    %vpi_call 2 48 "$monitor", "t=%0t | clk=%b rst=%b en=%b | count=%0d", $time, v0x644124649330_0, v0x644124679b80_0, v0x64412464abe0_0, v0x64412464a910_0 {0 0 0};
    %end;
    .thread T_5;
    .scope S_0x644124657b60;
T_6 ;
    %vpi_call 2 54 "$display", "=== Counter Testbench Start ===" {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x644124679b80_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x64412464abe0_0, 0, 1;
    %pushi/vec4 3, 0, 32;
T_6.0 %dup/vec4;
    %pushi/vec4 0, 0, 32;
    %cmp/s;
    %jmp/1xz T_6.1, 5;
    %jmp/1 T_6.1, 4;
    %pushi/vec4 1, 0, 32;
    %sub;
    %wait E_0x64412461e880;
    %jmp T_6.0;
T_6.1 ;
    %pop/vec4 1;
    %wait E_0x644124656eb0;
    %load/vec4 v0x64412464a910_0;
    %cmpi/ne 0, 0, 4;
    %jmp/0xz  T_6.2, 6;
    %vpi_call 2 61 "$display", "FAIL [reset]: expected 0, got %0d", v0x64412464a910_0 {0 0 0};
    %load/vec4 v0x644124679ae0_0;
    %addi 1, 0, 32;
    %store/vec4 v0x644124679ae0_0, 0, 32;
    %jmp T_6.3;
T_6.2 ;
    %vpi_call 2 64 "$display", "PASS [reset]: count = %0d", v0x64412464a910_0 {0 0 0};
T_6.3 ;
    %wait E_0x64412461e880;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x644124679b80_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x64412464abe0_0, 0, 1;
    %pushi/vec4 16, 0, 32;
T_6.4 %dup/vec4;
    %pushi/vec4 0, 0, 32;
    %cmp/s;
    %jmp/1xz T_6.5, 5;
    %jmp/1 T_6.5, 4;
    %pushi/vec4 1, 0, 32;
    %sub;
    %wait E_0x64412461e880;
    %jmp T_6.4;
T_6.5 ;
    %pop/vec4 1;
    %wait E_0x644124656eb0;
    %load/vec4 v0x64412464a910_0;
    %cmpi/ne 0, 0, 4;
    %jmp/0xz  T_6.6, 6;
    %vpi_call 2 77 "$display", "FAIL [wrap]: expected 0 after wrap, got %0d", v0x64412464a910_0 {0 0 0};
    %load/vec4 v0x644124679ae0_0;
    %addi 1, 0, 32;
    %store/vec4 v0x644124679ae0_0, 0, 32;
    %jmp T_6.7;
T_6.6 ;
    %vpi_call 2 80 "$display", "PASS [wrap]: count correctly wrapped to 0" {0 0 0};
T_6.7 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x64412464abe0_0, 0, 1;
    %wait E_0x64412461e880;
    %wait E_0x64412461e880;
    %wait E_0x644124656eb0;
    %load/vec4 v0x64412464a910_0;
    %cmpi/ne 0, 0, 4;
    %jmp/0xz  T_6.8, 6;
    %vpi_call 2 88 "$display", "FAIL [hold]: count changed during en=0, got %0d", v0x64412464a910_0 {0 0 0};
    %load/vec4 v0x644124679ae0_0;
    %addi 1, 0, 32;
    %store/vec4 v0x644124679ae0_0, 0, 32;
    %jmp T_6.9;
T_6.8 ;
    %vpi_call 2 91 "$display", "PASS [hold]: count held at 0 while en=0" {0 0 0};
T_6.9 ;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x64412464abe0_0, 0, 1;
    %pushi/vec4 5, 0, 32;
T_6.10 %dup/vec4;
    %pushi/vec4 0, 0, 32;
    %cmp/s;
    %jmp/1xz T_6.11, 5;
    %jmp/1 T_6.11, 4;
    %pushi/vec4 1, 0, 32;
    %sub;
    %wait E_0x64412461e880;
    %jmp T_6.10;
T_6.11 ;
    %pop/vec4 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x644124679b80_0, 0, 1;
    %wait E_0x64412461e880;
    %wait E_0x644124656eb0;
    %load/vec4 v0x64412464a910_0;
    %cmpi/ne 0, 0, 4;
    %jmp/0xz  T_6.12, 6;
    %vpi_call 2 101 "$display", "FAIL [mid-reset]: expected 0 after mid-stream reset, got %0d", v0x64412464a910_0 {0 0 0};
    %load/vec4 v0x644124679ae0_0;
    %addi 1, 0, 32;
    %store/vec4 v0x644124679ae0_0, 0, 32;
    %jmp T_6.13;
T_6.12 ;
    %vpi_call 2 104 "$display", "PASS [mid-reset]: synchronous reset works mid-stream" {0 0 0};
T_6.13 ;
    %vpi_call 2 108 "$display", "=================================" {0 0 0};
    %load/vec4 v0x644124679ae0_0;
    %cmpi/e 0, 0, 32;
    %jmp/0xz  T_6.14, 4;
    %vpi_call 2 110 "$display", "ALL TESTS PASSED" {0 0 0};
    %jmp T_6.15;
T_6.14 ;
    %vpi_call 2 112 "$display", "TESTS FAILED \342\200\224 %0d error(s)", v0x644124679ae0_0 {0 0 0};
T_6.15 ;
    %vpi_call 2 113 "$display", "=================================" {0 0 0};
    %vpi_call 2 115 "$finish" {0 0 0};
    %end;
    .thread T_6;
# The file index is used to find the file name in the following table.
:file_names 4;
