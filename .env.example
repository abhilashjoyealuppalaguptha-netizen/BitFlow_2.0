# .env.example — Copy to .env and edit before running the API.
#
#   cp .env.example .env
#
# Values shown are the defaults built into config.py.
# Only set a variable here if you want to OVERRIDE the default.
# Lines starting with # are comments and are ignored.

# ── Docker image ──────────────────────────────────────────────────────────────
# Name and tag of the pre-built Icarus Verilog sandbox image.
# Must match what you passed to `docker build -t`.
DOCKER_IMAGE=verilog-sandbox:latest

# ── Simulation timeouts ───────────────────────────────────────────────────────
# How long (seconds) vvp is allowed to run before being killed.
TIMEOUT_SECONDS=30

# Hard ceiling a client may request via the `timeout` field.
MAX_TIMEOUT_SECONDS=120

# ── Container resource caps ───────────────────────────────────────────────────
# Docker memory limit.  Format: <number><unit>  (b / k / m / g)
MEM_LIMIT=128m

# CPU throttling.  cpu_quota / cpu_period = fraction of one CPU core.
# 50000 / 100000 = 0.5 cores (50 %).
CPU_QUOTA=50000
CPU_PERIOD=100000

# Maximum PIDs inside the container.  Prevents fork bombs.
PIDS_LIMIT=64

# ── Networking ────────────────────────────────────────────────────────────────
# Set to false ONLY for local debugging.  Always true in production.
NETWORK_DISABLED=true

# ── Input limits ─────────────────────────────────────────────────────────────
# Maximum size (bytes) for each uploaded Verilog source file.
# Default: 524288 bytes = 512 KB
MAX_SOURCE_BYTES=524288

# ── API behaviour ─────────────────────────────────────────────────────────────
# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Whether to embed the VCD as base64 in the JSON response.
# Set to false if you intend to serve it as a separate download endpoint.
INCLUDE_VCD_IN_RESPONSE=true

# CORS allowed origins.  Use ["*"] for local dev; restrict in production.
# Format: JSON array of strings.
CORS_ORIGINS=["*"]
